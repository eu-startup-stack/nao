{
	"name": "@nao/sdk",
	"version": "0.1.0",
	"description": "Official TypeScript SDK for the nao analytics agent",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts --clean",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"nao",
		"analytics",
		"agent",
		"sdk",
		"llm"
	],
	"license": "MIT",
	"engines": {
		"node": ">=18"
	},
	"devDependencies": {
		"tsup": "^8.5.1",
		"typescript": "^5.7.0"
	}
}
